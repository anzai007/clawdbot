# Grindr 适配器环境变量示例
# 复制为 grindr.env 后再填入真实值
GRINDR_BASE_URL=https://grindr.mobi
GRINDR_AUTH_SCHEME=Grindr3
GRINDR_AUTH_TOKEN=replace_me
# 401 自动补救可选：无可用 session 时可尝试密码登录
GRINDR_AUTO_LOGIN_EMAIL=replace_me
GRINDR_AUTO_LOGIN_PASSWORD=replace_me
# /v8/sessions 可选 geohash（自动 refresh/login 会透传）
GRINDR_GEOHASH=c19752375b59fd507104d338f32e67ad0bcb578479977d0b8536fc70f96bec21
GRINDR_DEVICE_ID=replace_me
GRINDR_DEVICE_INFO=replace_me
GRINDR_LOCALE=zh_CN
GRINDR_TIME_ZONE=America/New_York
GRINDR_USER_AGENT=replace_me
GRINDR_TIMEOUT_SECONDS=20
GRINDR_RETRY_TIMES=2
GRINDR_LOG_DIR=./logs
GRINDR_SESSION_FILE=./.secrets/grindr.session.json
# discovery-reader 可选上游 endpoint（如需切换可覆盖）
GRINDR_DISCOVERY_NEARBY_ENDPOINT=/v1/cascade
GRINDR_DISCOVERY_VIEWED_ME_ENDPOINT=/v7/views/list
