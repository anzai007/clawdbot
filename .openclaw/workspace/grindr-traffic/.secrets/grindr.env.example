# Grindr 适配器环境变量示例
# 复制为 grindr.env 后再填入真实值
GRINDR_BASE_URL=https://grindr.mobi
GRINDR_AUTH_SCHEME=Grindr3
GRINDR_AUTH_TOKEN=replace_me
GRINDR_DEVICE_ID=replace_me
GRINDR_DEVICE_INFO=replace_me
GRINDR_LOCALE=zh_CN
GRINDR_TIME_ZONE=America/New_York
GRINDR_USER_AGENT=replace_me
GRINDR_TIMEOUT_SECONDS=20
GRINDR_RETRY_TIMES=2
GRINDR_LOG_DIR=./logs
GRINDR_SESSION_FILE=./.secrets/grindr.session.json
